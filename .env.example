# ---- Contact form email (Nodemailer + Gmail SMTP) ----
# Copy this file to ".env" and fill in real values. NEVER commit the real .env.

# The Gmail address that SENDS the messages (the authenticated SMTP user).
GMAIL_USER=your.address@gmail.com

# A 16-character Gmail "App Password" (NOT your normal Gmail password).
# How to create one:
#   1) Turn ON 2-Step Verification: https://myaccount.google.com/security
#   2) Go to App passwords: https://myaccount.google.com/apppasswords
#   3) Create a password (any app name) and paste the 16 chars below (spaces optional).
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where contact-form messages are delivered (your inbox).
CONTACT_TO=mariamthabet2003@gmail.com
